# Live credentials — never commit. Ship config_example.yaml instead.
# Leading slash anchors this to the repo ROOT: an unanchored "config.yaml"
# also matches at any depth and would silently exclude the test fixture
# (tests/fixtures/config.yaml), breaking CI with no obvious cause.
/config.yaml

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# Test artifacts. Trailing glob also covers rotated logs (test_run.log.1,
# .log.2, ...) — the bare *.log rule below does NOT match the .log.N suffix.
tests/fixtures/test_run.log*
.pytest_cache/
.ruff_cache/

# Logs and runtime artifacts
*.log
logs/
*.wav

# Editors / OS
.vscode/
.idea/
.DS_Store
